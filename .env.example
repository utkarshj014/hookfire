# ==============================================================================
# Hookfire - Root Environment Variables (Compose Level)
# ==============================================================================

# PostgreSQL Credentials & Storage Defaults
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hookfire

# Redis Authentication Password
REDIS_PASSWORD=my-redis-secure-password

# Application Cryptographic Security Keys
# ENCRYPTION_KEY must be exactly 32 bytes (32 characters) for AES-256-GCM.
ENCRYPTION_KEY=12345678901234567890123456789012
# Global fallback signing secret for webhook payloads.
WEBHOOK_SECRET=global-webhook-fallback-secret

# List of allowed origins for CORS (comma-separated).
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Target URL for API endpoints consumed by Vite client
VITE_API_URL="http://localhost:3000"

