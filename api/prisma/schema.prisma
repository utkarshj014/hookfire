generator client {
  provider = "prisma-client-js"
}

datasource db { 
  provider = "postgresql"
}

model Event {
  id        String   @id @default(cuid())
  eventType String   @map("event_type")
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  deliveries Delivery[]

  @@index([eventType, createdAt])

  @@map("event")
}

model Delivery {
  id            String   @id @default(cuid())
  
  eventId       String   @map("event_id")
  event         Event    @relation(fields: [eventId], references: [id])
  
  endpointId    String   @map("endpoint_id")
  endpoint      WebhookEndpoint @relation(fields: [endpointId], references: [id])

  status        String
  attemptCount  Int      @default(0) @map("attempt_count")
  latestError   String?  @map("latest_error")
  lastAttemptAt DateTime? @map("last_attempt_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  attempts      DeliveryAttempt[]
  
  @@index([status])
  @@index([eventId, endpointId])

  @@map("delivery")
}

model DeliveryAttempt {
  id            String   @id @default(cuid())
  
  deliveryId    String   @map("delivery_id")
  delivery      Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  status        String
  attemptNumber Int      @map("attempt_number")
  errorMessage  String?  @map("error_message")
  startedAt     DateTime @default(now()) @map("started_at")
  finishedAt    DateTime @updatedAt @map("finished_at")

  @@index([deliveryId])

  @@map("delivery_attempt")
}

model WebhookEndpoint {
  id                      String    @id @default(cuid())
  url                     String    @unique
  
  secretEncrypted         String    @map("secret_encrypted")
  secretIv                String    @map("secret_iv")
  secretTag               String    @map("secret_tag")

  previousSecretEncrypted String?   @map("previous_secret_encrypted")
  previousSecretIv        String?   @map("previous_secret_iv")
  previousSecretTag       String?   @map("previous_secret_tag")

  rotatedAt               DateTime? @map("rotated_at")
  isActive                Boolean   @default(true) @map("is_active")
  createdAt               DateTime  @default(now()) @map("created_at")

  deliveries              Delivery[]
  subscriptions           EndpointSubscription[]
  
  @@map("webhook_endpoint")
}

model EndpointSubscription {
  id         String          @id @default(cuid())
  
  endpointId String          @map("endpoint_id")
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  
  eventType  String          @map("event_type")
  createdAt  DateTime        @default(now()) @map("created_at")

  @@unique([endpointId, eventType])

  @@map("endpoint_subscription")
}

model ProcessedWebhook {
  id         String   @id @default(cuid())
  deliveryId String   @unique @map("delivery_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("processed_webhook")
}