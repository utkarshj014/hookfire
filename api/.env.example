# ==============================================================================
# Hookfire - Backend API Service Environment Variables
# ==============================================================================

# Database Connection URI (Prisma format)
# Note: Host points to 'postgres' when running inside Docker Compose.
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/hookfire?schema=public"

# Redis Server Configuration
# Note: Host points to 'redis' when running inside Docker Compose.
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_PASSWORD="my-redis-secure-password"

# Cryptographic Keys
# ENCRYPTION_KEY must be exactly 32 bytes (32 characters) for AES-256-GCM.
ENCRYPTION_KEY="12345678901234567890123456789012"
# Fallback signature verification secret.
WEBHOOK_SECRET="global-webhook-fallback-secret"

# List of allowed origins for CORS (comma-separated).
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Server Port & Execution Target
PORT=3000
NODE_ENV="development"